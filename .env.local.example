# Anthropic (via AWS)
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=

# Moonshot
MOONSHOT_API_KEY=

# Gemini (Google AI Studio) — for web search grounding
GEMINI_API_KEY=

# Optional outbound HTTP policy for web-capable tools
# OUTBOUND_HTTP_MODE=auto
# OUTBOUND_PROXY_URL=http://127.0.0.1:1087
# OUTBOUND_NO_PROXY=localhost,127.0.0.1,::1
# OUTBOUND_ALLOW_DIRECT_FALLBACK=false
# OUTBOUND_HTTP_TIMEOUT_MS=10000
#
# Standard proxy env vars like HTTPS_PROXY / HTTP_PROXY / NO_PROXY are also honored.

# Database
DATABASE_URL=mysql://root:password@localhost:3306/agent
